pub use super::lifetime_environment::{LifetimeToken, RefType, VarDecl};
use std::collections::HashMap;

// ========== Lifetime Relation ==========

#[derive(Clone, Debug, PartialEq, Eq)]
pub enum LifetimeRelation {
    Equal,           // 'a = 'b
    Outlives,        // 'a > 'b ('a lives longer)
    Outlived,        // 'a < 'b ('a lives shorter)
    Unknown,         // 'a ? 'b
}

// ========== Function Signature ==========

#[derive(Clone, Debug)]
pub struct FunctionSignature {
    pub name: String,
    pub lifetime_params: Vec<LifetimeToken>,
    pub param_lifetimes: Vec<LifetimeToken>,
    pub return_lifetime: LifetimeToken,
}

impl FunctionSignature {
    pub fn new(
        name: String,
        lifetime_params: Vec<LifetimeToken>,
        param_lifetimes: Vec<LifetimeToken>,
        return_lifetime: LifetimeToken,
    ) -> Self {
        Self {
            name,
            lifetime_params,
            param_lifetimes,
            return_lifetime,
        }
    }

    pub fn validate_signature(&self) -> bool {
        // ŽįėŪôė lifetimežĚī žĄ†žĖłŽźú lifetime Ž≤ĒžúĄ Žāīžó¨žēľ Ūē®
        if self.return_lifetime.is_named() {
            self.lifetime_params.contains(&self.return_lifetime) ||
            self.return_lifetime.is_static()
        } else {
            true
        }
    }
}

// ========== Lifetime Inference ==========

pub struct LifetimeInferencer {
    pub inferred_lifetimes: HashMap<u32, LifetimeToken>,
    pub lifetime_constraints: Vec<(LifetimeToken, LifetimeToken)>,
    pub inference_id: u32,
}

impl LifetimeInferencer {
    pub fn new() -> Self {
        Self {
            inferred_lifetimes: HashMap::new(),
            lifetime_constraints: Vec::new(),
            inference_id: 0,
        }
    }

    pub fn infer_lifetime(&mut self, var_id: u32, ref_type: RefType) -> LifetimeToken {
        // žĚīŽĮł ž∂ĒŽ°†Žźú lifetimežĚī žěąžúľŽ©ī ŽįėŪôė
        if let Some(lt) = self.inferred_lifetimes.get(&var_id) {
            return *lt;
        }

        // žÉą anonymous lifetime žÉĚžĄĪ
        let lifetime = LifetimeToken::Anonymous(self.inference_id);
        self.inference_id += 1;

        self.inferred_lifetimes.insert(var_id, lifetime);
        lifetime
    }

    pub fn add_constraint(&mut self, longer: LifetimeToken, shorter: LifetimeToken) {
        // ž§ĎŽ≥Ķ ž†úžēĹ Žį©žßÄ
        if !self.lifetime_constraints.iter().any(|(a, b)| a == &longer && b == &shorter) {
            self.lifetime_constraints.push((longer, shorter));
        }
    }

    pub fn solve_constraints(&self) -> HashMap<LifetimeToken, LifetimeToken> {
        let mut solution = HashMap::new();

        // Static lifetime is fixed
        solution.insert(LifetimeToken::Static, LifetimeToken::Static);

        // For each constraint, try to deduce lifetime relationships
        for (longer, shorter) in &self.lifetime_constraints {
            if let LifetimeToken::Named(_) = longer {
                solution.insert(*longer, *longer);
            }
            if let LifetimeToken::Named(_) = shorter {
                solution.insert(*shorter, *shorter);
            }
        }

        solution
    }

    pub fn get_inferred_lifetime(&self, var_id: u32) -> Option<LifetimeToken> {
        self.inferred_lifetimes.get(&var_id).copied()
    }

    pub fn constraint_count(&self) -> usize {
        self.lifetime_constraints.len()
    }

    pub fn reset(&mut self) {
        self.inferred_lifetimes.clear();
        self.lifetime_constraints.clear();
        self.inference_id = 0;
    }
}

// ========== Lifetime Analyzer ==========

pub struct LifetimeAnalyzer {
    pub inferencer: LifetimeInferencer,
    pub function_signatures: Vec<FunctionSignature>,
    pub lifetime_relations: Vec<(u32, u32, LifetimeRelation)>,
}

impl LifetimeAnalyzer {
    pub fn new() -> Self {
        Self {
            inferencer: LifetimeInferencer::new(),
            function_signatures: Vec::new(),
            lifetime_relations: Vec::new(),
        }
    }

    pub fn register_function(&mut self, sig: FunctionSignature) -> bool {
        if !sig.validate_signature() {
            return false;
        }

        self.function_signatures.push(sig);
        true
    }

    pub fn analyze_reference_chain(
        &mut self,
        var_ids: Vec<u32>,
        ref_types: Vec<RefType>,
    ) -> Vec<LifetimeToken> {
        let mut result = Vec::new();

        for (i, &var_id) in var_ids.iter().enumerate() {
            let ref_type = ref_types.get(i).copied().unwrap_or(RefType::Shared);
            let lifetime = self.inferencer.infer_lifetime(var_id, ref_type);
            result.push(lifetime);

            // Add constraints between consecutive references
            if i > 0 {
                let prev_lifetime = result[i - 1];
                // Current reference must not outlive previous
                self.inferencer.add_constraint(prev_lifetime, lifetime);
            }
        }

        result
    }

    pub fn record_lifetime_relation(&mut self, var1: u32, var2: u32, relation: LifetimeRelation) {
        self.lifetime_relations.push((var1, var2, relation));
    }

    pub fn get_lifetime_relation(&self, var1: u32, var2: u32) -> Option<LifetimeRelation> {
        self.lifetime_relations
            .iter()
            .find(|(a, b, _)| (*a == var1 && *b == var2) || (*a == var2 && *b == var1))
            .map(|(_, _, rel)| rel.clone())
    }

    pub fn analyze_function_call(
        &mut self,
        func_name: &str,
        arg_lifetimes: Vec<LifetimeToken>,
    ) -> Option<LifetimeToken> {
        // Find function signature
        let sig = self
            .function_signatures
            .iter()
            .find(|s| s.name == func_name)?;

        // Check if argument lifetimes match parameter count
        if arg_lifetimes.len() != sig.param_lifetimes.len() {
            return None;
        }

        // Return the function's return lifetime
        Some(sig.return_lifetime)
    }

    pub fn infer_all_lifetimes(&mut self, var_ids: Vec<u32>) -> HashMap<u32, LifetimeToken> {
        let mut result = HashMap::new();

        for var_id in var_ids {
            let lifetime = self.inferencer.infer_lifetime(var_id, RefType::Shared);
            result.insert(var_id, lifetime);
        }

        result
    }

    pub fn get_analysis_report(&self) -> String {
        format!(
            "LifetimeAnalysis {{ functions: {}, relations: {}, constraints: {} }}",
            self.function_signatures.len(),
            self.lifetime_relations.len(),
            self.inferencer.constraint_count()
        )
    }

    pub fn reset(&mut self) {
        self.inferencer.reset();
        self.function_signatures.clear();
        self.lifetime_relations.clear();
    }
}

// ========== Tests (C1-C6) ==========

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_c1_lifetime_inference() {
        let mut inferencer = LifetimeInferencer::new();

        let lt1 = inferencer.infer_lifetime(1, RefType::Shared);
        let lt2 = inferencer.infer_lifetime(1, RefType::Shared);

        // Same variable should get same lifetime
        assert_eq!(lt1, lt2);
    }

    #[test]
    fn test_c2_constraint_addition() {
        let mut inferencer = LifetimeInferencer::new();
        let lt_a = LifetimeToken::new_named("a");
        let lt_b = LifetimeToken::new_named("b");

        inferencer.add_constraint(lt_a, lt_b);
        assert_eq!(inferencer.constraint_count(), 1);

        // Duplicate constraint should not be added
        inferencer.add_constraint(lt_a, lt_b);
        assert_eq!(inferencer.constraint_count(), 1);
    }

    #[test]
    fn test_c3_function_signature() {
        let sig = FunctionSignature::new(
            "borrow".to_string(),
            vec![LifetimeToken::new_named("a")],
            vec![LifetimeToken::new_named("a")],
            LifetimeToken::new_named("a"),
        );

        assert!(sig.validate_signature());
    }

    #[test]
    fn test_c4_reference_chain_analysis() {
        let mut analyzer = LifetimeAnalyzer::new();

        let var_ids = vec![1, 2, 3];
        let ref_types = vec![RefType::Shared, RefType::Shared, RefType::Shared];

        let lifetimes = analyzer.analyze_reference_chain(var_ids, ref_types);
        assert_eq!(lifetimes.len(), 3);
    }

    #[test]
    fn test_c5_lifetime_relations() {
        let mut analyzer = LifetimeAnalyzer::new();

        analyzer.record_lifetime_relation(1, 2, LifetimeRelation::Outlives);
        let relation = analyzer.get_lifetime_relation(1, 2);

        assert_eq!(relation, Some(LifetimeRelation::Outlives));
    }

    #[test]
    fn test_c6_function_call_analysis() {
        let mut analyzer = LifetimeAnalyzer::new();

        let sig = FunctionSignature::new(
            "get_ref".to_string(),
            vec![LifetimeToken::new_named("a")],
            vec![LifetimeToken::new_named("a")],
            LifetimeToken::new_named("a"),
        );

        assert!(analyzer.register_function(sig));

        let lt_arg = LifetimeToken::new_named("a");
        let result = analyzer.analyze_function_call("get_ref", vec![lt_arg]);

        assert!(result.is_some());
    }
}

