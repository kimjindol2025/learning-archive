"""Token types and Token class for Gogs Lexer"""

from enum import Enum, auto
from dataclasses import dataclass
from typing import Any

class TokenType(Enum):
    """All token types in Gogs language"""
    
    # Literals
    INT = auto()
    FLOAT = auto()
    STRING = auto()
    IDENT = auto()
    
    # Keywords
    LET = auto()
    FN = auto()
    IF = auto()
    ELSE = auto()
    RETURN = auto()
    WHILE = auto()
    TRUE = auto()
    FALSE = auto()
    NULL = auto()
    
    # Operators
    PLUS = auto()
    MINUS = auto()
    ASTERISK = auto()
    SLASH = auto()
    PERCENT = auto()
    EQUAL = auto()
    NOT_EQUAL = auto()
    LESS_THAN = auto()
    GREATER_THAN = auto()
    LESS_EQUAL = auto()
    GREATER_EQUAL = auto()
    BANG = auto()
    AMPERSAND = auto()
    PIPE = auto()
    CARET = auto()
    ASSIGN = auto()
    
    # Delimiters
    LPAREN = auto()
    RPAREN = auto()
    LBRACE = auto()
    RBRACE = auto()
    LBRACKET = auto()
    RBRACKET = auto()
    SEMICOLON = auto()
    COLON = auto()
    COMMA = auto()
    DOT = auto()
    ARROW = auto()
    FAT_ARROW = auto()
    ELLIPSIS = auto()
    
    # Special
    NEWLINE = auto()
    EOF = auto()
    UNKNOWN = auto()

@dataclass
class Position:
    """Source code position"""
    line: int
    column: int
    byte_offset: int

@dataclass
class Token:
    """Token with position information"""
    type: TokenType
    literal: Any
    position: Position
    
    def __repr__(self) -> str:
        return f"Token({self.type.name}, {self.literal!r}, [{self.position.line}:{self.position.column}])"
