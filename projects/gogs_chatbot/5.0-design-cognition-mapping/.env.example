# 5.0 설계 사고 지도 엔진 설정

# 개념 추출 설정
CONCEPT_EXTRACTION_ENABLED=true
CORE_CONCEPTS_ENABLED=true
KEYWORD_EXTRACTION_ENABLED=true
MIN_CONCEPT_FREQUENCY=1

# 개념 그래프 설정
GRAPH_BUILDING_ENABLED=true
EDGE_CREATION_RULES=co-occurrence|co-location|sequence|dependency
EDGE_STRENGTH_WEIGHTING=true

# 중심성 분석 설정
CENTRALITY_ANALYSIS_ENABLED=true
DEGREE_CENTRALITY_ENABLED=true
BETWEENNESS_CENTRALITY_ENABLED=true
PAGERANK_ENABLED=true
PAGERANK_ITERATIONS=10
PAGERANK_DAMPING_FACTOR=0.85

# 개념 역할 분류
CONCEPT_ROLE_CLASSIFICATION=true
CORE_THRESHOLD=0.6
EXPANSION_THRESHOLD=0.3
ROLE_CATEGORIES=core|hub|expansion|boundary|peripheral

# 아키텍처 계층
ARCHITECTURE_LAYER_GENERATION=true
LAYER_COUNT=3

# 설계 사고 지도
COGNITION_MAP_GENERATION=true
MAP_VISUALIZATION_ENABLED=true
NODE_POSITIONING_ALGORITHM=layer-based

# 사고 확장 패턴
PATTERN_ANALYSIS_ENABLED=true
PHASE_EVOLUTION_TRACKING=true
COGNITION_SHIFT_ANALYSIS=true
CONCEPT_DIFFUSION_ANALYSIS=true
PATTERN_DETECTION_ENABLED=true

# 구조 분석
STRUCTURAL_EVOLUTION_TRACKING=true
CONCEPT_DENSITY_CALCULATION=true
CONNECTIVITY_ANALYSIS=true

# 출력 설정
OUTPUT_FORMAT=json
GENERATE_REPORTS=true
VISUALIZATION_FORMAT=graphviz
SAVE_ANALYSIS_DATA=true

# 로깅
DEBUG_MODE=false
VERBOSE_LOGGING=false
