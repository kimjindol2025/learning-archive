# 시간축 진화 추론 엔진 설정

# Git 저장소 경로
GIT_REPO_PATH=/path/to/repository

# Git 분석 설정
GIT_LOG_LIMIT=1000
GIT_LOG_FORMAT=%H|%P|%ai|%s|%an|%ae

# Commit 분석 설정
COMMIT_TYPE_DETECTION=true
VERSION_PATTERN=v\\d+\\.\\d+(?:\\.\\d+)?
PHASE_PATTERN=phase\\s+\\d+

# Diff 분석 설정
DIFF_MAJOR_CHANGE_THRESHOLD=50
DIFF_REFACTORING_THRESHOLD=500
DIFF_EXPANSION_RATIO=0.7

# 기능 추적 설정
FEATURE_TRACKING_ENABLED=true
FEATURE_MENTION_MIN_COUNT=1

# 진화 속도 계산
VELOCITY_CALCULATION_ENABLED=true

# 리포트 생성 설정
REPORT_FORMAT=markdown
REPORT_INCLUDE_DESIGN_INTENT=true
REPORT_INCLUDE_STATISTICS=true

# DAG 분석
DAG_BUILD_ENABLED=true
DAG_STATISTICS_ENABLED=true

# 기능 의존성 분석
DEPENDENCY_ANALYSIS_ENABLED=true

# 라깅 설정
DEBUG_MODE=false
VERBOSE_LOGGING=false
