# 4.0 설계 의도 추출 엔진 설정

# Claude API (LLM 기반 의도 추출)
CLAUDE_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-opus-4-6

# Git 저장소 설정
GIT_REPO_PATH=/path/to/repository

# 설계 의도 분류 설정
INTENT_CATEGORIES=Architecture|Performance|API|Verification|Refactoring|Quality|Optimization|Other
INTENT_CONFIDENCE_THRESHOLD=0.5
INTENT_LLM_ENABLED=true

# 영향도 계산 설정
IMPACT_FILE_WEIGHT=0.3
IMPACT_SIZE_WEIGHT=0.4
IMPACT_COMPLEXITY_WEIGHT=0.3

# 아키텍처 그래프 설정
ARCHITECTURE_GRAPH_ENABLED=true
CLUSTER_THRESHOLD=0.7
CONCEPT_EXTRACTION_ENABLED=true

# 의존성 맵 설정
DEPENDENCY_MAPPER_ENABLED=true
CYCLE_DETECTION_ENABLED=true
DEPENDENCY_DEPTH_LIMIT=5

# 진화 메트릭 설정
EVOLUTION_METRICS_ENABLED=true
DENSITY_CALCULATION_ENABLED=true
MATURITY_SCORING_ENABLED=true
INNOVATION_INDEX_ENABLED=true
INTELLIGENCE_SCORE_ENABLED=true

# 복잡도 분석
COMPLEXITY_TRACKING_ENABLED=true
ARCHITECTURE_DEPTH_ENABLED=true
CONCEPT_DIVERSITY_ENABLED=true

# 출력 설정
OUTPUT_FORMAT=json
GENERATE_REPORTS=true
REPORT_FORMAT=markdown

# 로깅
DEBUG_MODE=false
VERBOSE_LOGGING=false
SAVE_ANALYSIS_LOGS=true
