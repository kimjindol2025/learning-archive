# 7.0 능동적 설계 보조 시스템 설정

# 경고 감지 설정
WARNING_DETECTION_ENABLED=true
CENTRALITY_SPIKE_DETECTION=true
CENTRALITY_SPIKE_THRESHOLD=0.4
DEPENDENCY_CONGESTION_DETECTION=true
DEPENDENCY_CONGESTION_THRESHOLD=3
TEST_SLOWDOWN_DETECTION=true
TEST_SLOWDOWN_WINDOW=5
ISOLATED_NODE_DETECTION=true
STRUCTURAL_SHIFT_DETECTION=true
STRUCTURAL_SHIFT_THRESHOLD=0.3
CIRCULAR_DEPENDENCY_DETECTION=true

# 균형 계산 설정
BALANCE_CALCULATION_ENABLED=true
BALANCE_INDEX_ENABLED=true
BALANCE_TREND_ANALYSIS=true
IDEAL_BALANCE_INDEX=0.5
MIN_BALANCE_INDEX=0.4
MAX_BALANCE_INDEX=0.6

# 패턴 인식 설정
PATTERN_EXTRACTION_ENABLED=true
PATTERN_COMPARISON_ENABLED=true
CONCEPT_SIMILARITY_THRESHOLD=0.6
PATTERN_RECOMMENDATION_ENABLED=true
PATTERN_CONFIDENCE_THRESHOLD=0.6

# 진화 예측 설정
EVOLUTION_PREDICTION_ENABLED=true
CONCEPT_GROWTH_ANALYSIS=true
TEST_COVERAGE_PREDICTION=true
NEXT_VALUES_PREDICTION=true
PREDICTION_STEPS=3
PREDICTION_CONFIDENCE_THRESHOLD=0.5

# 설계 파트너 설정
DESIGN_ADVISOR_ENABLED=true
ADVISORY_MESSAGE_GENERATION=true
ACTION_ITEM_GENERATION=true
PRIORITY_CALCULATION=true

# 위험 및 기회 식별
RISK_IDENTIFICATION_ENABLED=true
OPPORTUNITY_IDENTIFICATION_ENABLED=true
WISDOM_GENERATION_ENABLED=true

# 심각도 레벨
WARNING_SEVERITY_LEVELS=CRITICAL|HIGH|MEDIUM|LOW
ACTION_PRIORITY_LEVELS=P0|P1|P2

# 출력 설정
OUTPUT_FORMAT=json
GENERATE_ADVISORY_REPORT=true
GENERATE_ACTION_PLAN=true
SAVE_ANALYSIS_STATE=true

# 로깅
DEBUG_MODE=false
VERBOSE_LOGGING=false
TRACE_PREDICTIONS=false
