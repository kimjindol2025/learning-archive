# 6.0 다중 Repo 통합 & 생태계 분석 엔진 설정

# 저장소 메타데이터
REPOSITORY_METADATA_ENABLED=true
REPOSITORY_CLASSIFICATION_ENABLED=true
REPO_TYPE_CATEGORIES=core|theoretical|experimental|application|mixed

# 다중 저장소 통합
MULTI_REPO_AGGREGATION_ENABLED=true
GLOBAL_STATISTICS_CALCULATION=true
CONCEPT_ORIGIN_TRACKING=true

# 개념 전이 분석
CONCEPT_TRANSFER_DETECTION_ENABLED=true
TRANSFER_VELOCITY_ANALYSIS=true
TRANSFER_LAG_CALCULATION=true
INFLUENTIAL_TRANSFER_IDENTIFICATION=true

# 저장소 영향력 분석
REPOSITORY_INFLUENCE_CALCULATION=true
INFLUENCE_SCORING_ENABLED=true
INFLUENCE_TYPE_WEIGHTING=true

# 생태계 건강도
ECOSYSTEM_HEALTH_ANALYSIS=true
ECOSYSTEM_DIVERSITY_CALCULATION=true
ECOSYSTEM_STABILITY_MEASUREMENT=true
ECOSYSTEM_GROWTH_TRACKING=true
ECOSYSTEM_CONNECTIVITY_ANALYSIS=true

# 생태계 성숙도
ECOSYSTEM_MATURITY_CALCULATION=true
BALANCE_CALCULATION=true
CONCENTRATION_ANALYSIS=true
ROLE_CERTAINTY_MEASUREMENT=true

# 생태계 구조
ECOSYSTEM_STRUCTURE_ANALYSIS=true
ROLE_CLASSIFICATION=true
COMMUNICATION_PATH_MAPPING=true
BOTTLENECK_DETECTION=true

# 패턴 전이 감지
PATTERN_TRANSFER_DETECTION=true
TRANSFER_PATH_PATTERN_IDENTIFICATION=true
CONCEPT_TRAJECTORY_TRACING=true
PATTERN_CLASSIFICATION=true
CYCLE_DETECTION=true
FAN_OUT_DETECTION=true
FAN_IN_DETECTION=true
DIAMOND_PATTERN_DETECTION=true

# 영향 확산 분석
INFLUENCE_DIFFUSION_ANALYSIS=true
DIFFUSION_SPEED_CALCULATION=true
DIFFUSION_ACCELERATION_TRACKING=true

# 저장소 영향 프로필
REPOSITORY_INFLUENCE_PROFILE_BUILDING=true
PROFILE_REACH_CALCULATION=true
PROFILE_SOURCE_CALCULATION=true

# 추천 생성
ECOSYSTEM_RECOMMENDATION_GENERATION=true

# 출력 설정
OUTPUT_FORMAT=json
GENERATE_REPORTS=true
VISUALIZATION_FORMAT=graphviz
SAVE_ANALYSIS_DATA=true
SAVE_ECOSYSTEM_METRICS=true

# 로깅
DEBUG_MODE=false
VERBOSE_LOGGING=false
TRACE_TRANSFERS=false
