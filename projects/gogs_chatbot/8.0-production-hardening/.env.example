# 8.0 운영 안정화 시스템 설정

# 기능 관리 설정
FEATURE_FREEZE_ENABLED=true
REQUIRED_FEATURES=CHUNK_PROCESSING|METADATA_FILTERING|BM25_RANKING|HYBRID_SEARCH

# 로깅 시스템 설정
LOGGING_ENABLED=true
LOG_SEARCH_SESSIONS=true
LOG_COMMITS_USED=true
LOG_FILTERS_APPLIED=true
LOG_PROMPTS=true
LOG_LLM_RESPONSES=true
LOG_METADATA=true
LOG_ERRORS=true
SESSION_LOG_RETENTION=1000
LOG_FORMAT=json
LOG_OUTPUT_DIR=/var/log/gogs-knowledge-engine

# 재현성 테스트 설정
REPRODUCIBILITY_TESTING_ENABLED=true
TEST_ITERATION_COUNT=3
REPRODUCIBILITY_TOLERANCE=EXACT
TEST_QUERY_SAMPLING=0.1
SCHEDULE_REPRODUCIBILITY_TESTS=true
TEST_SCHEDULE_INTERVAL=86400000

# 버전 관리 설정
VERSION_MANAGEMENT_ENABLED=true
VERSION_COMPONENTS=BM25_INDEX|VECTOR_INDEX|METADATA_SCHEMA|LLM_MODEL|PROMPT
REQUIRED_COMPONENTS_FOR_DEPLOYMENT=5
VERSION_LOCK_ENABLED=true
COMPATIBILITY_CHECK_ON_DEPLOY=true

# 메타데이터 스키마 버전
METADATA_SCHEMA_VERSION=1.0
SCHEMA_MIGRATION_MODE=STRICT
SCHEMA_VALIDATION_ON_QUERY=true

# 모델 고정
LLM_MODEL_LOCK=gpt-4-latest
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=2048
LLM_TIMEOUT=30000
FALLBACK_MODEL=gpt-3.5-turbo

# 프롬프트 버전
SYSTEM_PROMPT_VERSION=1.0
SYSTEM_PROMPT_LOCK=true
PROMPT_VALIDATION_ON_BOOT=true

# 인덱스 설정
BM25_INDEX_VERSION=1.4
VECTOR_INDEX_VERSION=2.0
INDEX_VALIDATION_INTERVAL=3600000
INDEX_BACKUP_ENABLED=true
INDEX_BACKUP_RETENTION=10

# 데이터 동기화
GOGS_SYNC_ENABLED=true
INCREMENTAL_SYNC_ENABLED=true
FULL_REINDEX_SCHEDULE=0 2 * * 0
SYNC_FAILURE_ALERT=true
MAX_SYNC_FAILURES_BEFORE_ESCALATION=3

# 복구 설정
AUTO_RECOVERY_ENABLED=true
RECOVERY_SCENARIOS=INDEX_CORRUPTION|VECTOR_STORE_FAILURE|LLM_API_FAILURE|METADATA_SCHEMA_MISMATCH|MEMORY_EXHAUSTION|GOGS_SYNC_FAILURE
AUTO_RECOVERY_MAX_RETRIES=3
RECOVERY_RETRY_BACKOFF=2000
RECOVERY_ESCALATION_TIME=300000

# 모니터링 및 경고
HEALTH_CHECK_INTERVAL=60000
ERROR_RATE_THRESHOLD=0.05
P99_LATENCY_THRESHOLD=2000
MEMORY_USAGE_THRESHOLD=0.85
ALERT_CHANNEL=slack
ALERT_SEVERITY_THRESHOLD=HIGH

# 감사 추적
AUDIT_TRAIL_ENABLED=true
AUDIT_LOG_RETENTION=2592000000
AUDIT_LOG_LOCATION=/var/log/gogs-audit

# 보안 설정
API_KEY_ROTATION_ENABLED=true
API_KEY_ROTATION_INTERVAL=2592000000
GOGS_AUTH_TOKEN_SECURE=true
ENCRYPTION_ENABLED=true

# 성능 조정
BATCH_SIZE=10
CACHE_SIZE=100000
SEARCH_TIMEOUT=5000
INDEX_BUILD_TIMEOUT=120000

# 배포 설정
DEPLOYMENT_MODE=SINGLE_SERVER
DEPLOYMENT_VALIDATION_REQUIRED=true
ROLLBACK_ON_FAILED_HEALTH_CHECK=true
STARTUP_HEALTH_CHECK_TIMEOUT=30000

# 로깅 레벨
LOG_LEVEL=INFO
DEBUG_MODE=false
VERBOSE_LOGGING=false
TRACE_VERSION_CHANGES=false
TRACE_RECOVERY_EXECUTION=false

# 기타
SYSTEM_TIMEZONE=UTC
MAINTENANCE_WINDOW=02:00-03:00 UTC
BACKUP_ENABLED=true
BACKUP_INTERVAL=86400000
