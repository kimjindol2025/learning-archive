// FizzBuzz in FreeLang

fn fizzbuzz(): i32 {
    for i in range(1, 100) {
        if i % 15 == 0 {
            println("FizzBuzz");
        } else if i % 3 == 0 {
            println("Fizz");
        } else if i % 5 == 0 {
            println("Buzz");
        } else {
            println(i);
        }
    }
    return 0;
}

fn main(): i32 {
    return fizzbuzz();
}
